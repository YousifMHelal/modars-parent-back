datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum ParentRole {
  OWNER
  CO_PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum ChildStatus {
  ACTIVE
  PAUSED
}

enum Curriculum {
  BRITISH
  AMERICAN
  IB
  SAUDI_NATIONAL
}

enum Trend {
  UP
  DOWN
  FLAT
}

enum HomeworkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  COMPLETED_LATE
}

enum PlanKey {
  STARTER
  FAMILY
  FAMILY_PRO
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  PAID
  OPEN
  VOID
}

enum ReminderType {
  DAILY_STUDY
  HOMEWORK_DUE
  STREAK_PROTECTION
  MISSED_SESSION
  WEEKLY_SUMMARY
  STRUGGLE_ALERT
  EXAM_COUNTDOWN
  ACHIEVEMENT
  REWARD_REDEEMED
}

enum ReminderRecipient {
  CHILD
  PARENT
  BOTH
}

enum NotificationRecipient {
  PARENT
  CHILD
}

enum RewardStatus {
  ACTIVE
  FULFILLED
  EXPIRED
}

enum MessageType {
  TEXT
  VOICE
  IMAGE
}

enum MessageSenderType {
  PARENT
  TEACHER
  CHILD
}

enum ConsentType {
  TERMS
  PRIVACY
  COPPA
  MARKETING
}

// ── Models ────────────────────────────────────────────────────────────────────

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parents       Parent[]
  children      Child[]
  subscription  Subscription?
  sessions      Session[]
  subjectProgress SubjectProgress[]
  homework      Homework[]
  reminderConfigs ReminderConfig[]
  badges        Badge[]
  notifications Notification[]
  rewards       Reward[]
  conversations Conversation[]
  consentRecords ConsentRecord[]
}

model Parent {
  id            String     @id @default(cuid())
  familyId      String
  role          ParentRole
  fullName      String
  email         String     @unique
  phoneCountry  String?
  phoneNumber   String?
  country       String?
  dob           DateTime?
  passwordHash  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  family         Family          @relation(fields: [familyId], references: [id], onDelete: Restrict)
  consentRecords ConsentRecord[]

  @@index([familyId])
}

model Child {
  id                  String      @id @default(cuid())
  familyId            String
  displayName         String
  dob                 DateTime
  gender              Gender
  country             String
  grade               String
  curriculum          Curriculum
  subjects            String[]
  status              ChildStatus @default(ACTIVE)
  username            String
  usernameNormalized  String      @unique
  passwordHash        String?
  pinHash             String?

  // Snapshot stats (D6)
  minutesThisWeek     Int         @default(0)
  sessionsThisWeek    Int         @default(0)
  streak              Int         @default(0)
  totalXp             Int         @default(0)
  totalMinutes        Int         @default(0)
  badgesThisMonth     Int         @default(0)
  masteryPercentage   Int         @default(0)
  coveragePercentage  Int         @default(0)
  trendVsLastWeek     Int         @default(0)
  topSubject          String?

  // Gamification
  level               Int         @default(1)
  levelXp             Int         @default(0)
  levelMax            Int         @default(1000)
  nextLevel           Int         @default(2)
  streakTokens        Int         @default(0)

  // Parental controls
  bedtimeCutoff       String?
  allowedDays         String[]
  blockedSubjects     String[]

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  family          Family            @relation(fields: [familyId], references: [id], onDelete: Restrict)
  sessions        Session[]
  subjectProgress SubjectProgress[]
  homework        Homework[]
  badges          Badge[]
  reminderConfigs ReminderConfig[]
  notifications   Notification[]
  rewards         Reward[]
  conversations   Conversation[]
  consentRecords  ConsentRecord[]

  @@index([familyId])
}

model Plan {
  id                  String   @id @default(cuid())
  key                 PlanKey  @unique
  name                String
  subtitle            String
  childLimit          Int
  monthlyPriceMinor   Int
  yearlyPriceMinor    Int
  yearlyDiscountMinor Int
  currency            String
  features            String[]
  highlighted         Boolean  @default(false)
  hasFreeTrial        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  familyId         String             @unique
  planId           String
  status           SubscriptionStatus
  billingCycle     BillingCycle
  childSlotsUsed   Int                @default(0)
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Restrict)
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices Invoice[]
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  issuedAt       DateTime
  amountMinor    Int
  currency       String
  status         InvoiceStatus
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
}

model Session {
  id              String   @id @default(cuid())
  familyId        String
  childId         String
  subject         String
  startedAt       DateTime
  durationMinutes Int
  topics          String[]
  score           Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([childId])
}

model SubjectProgress {
  id            String    @id @default(cuid())
  familyId      String
  childId       String
  subject       String
  mastery       Int
  coverage      Int
  trend         Trend
  lastStudiedAt DateTime?
  masteryHistory Int[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  family Family         @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child          @relation(fields: [childId], references: [id], onDelete: Restrict)
  topics TopicProgress[]

  @@unique([childId, subject])
  @@index([familyId])
  @@index([childId])
}

model TopicProgress {
  id                String   @id @default(cuid())
  subjectProgressId String
  name              String
  mastery           Int
  struggling        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subjectProgress SubjectProgress @relation(fields: [subjectProgressId], references: [id], onDelete: Restrict)

  @@index([subjectProgressId])
}

model Homework {
  id       String         @id @default(cuid())
  familyId String
  childId  String
  subject  String
  topic    String
  deadline DateTime
  status   HomeworkStatus
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([childId])
}

model ReminderConfig {
  id        String            @id @default(cuid())
  familyId  String
  childId   String
  type      ReminderType
  enabled   Boolean
  recipient ReminderRecipient
  settings  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([childId, type])
  @@index([familyId])
  @@index([childId])
}

model Badge {
  id              String    @id @default(cuid())
  familyId        String
  childId         String
  key             String
  name            String
  emoji           String
  description     String
  criteria        String
  earned          Boolean   @default(false)
  earnedAt        DateTime?
  progressCurrent Int?
  progressTotal   Int?
  progressUnit    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([childId, key])
  @@index([familyId])
  @@index([childId])
}

model Notification {
  id        String                @id @default(cuid())
  familyId  String
  recipient NotificationRecipient
  childId   String?
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child? @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
}

model Reward {
  id          String       @id @default(cuid())
  familyId    String
  childId     String?
  title       String
  description String?
  goalTarget  Int?
  goalCurrent Int?
  status      RewardStatus
  fulfilledAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child? @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
}

model Conversation {
  id            String    @id @default(cuid())
  familyId      String
  childId       String?
  teacherId     String?
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child    Child?    @relation(fields: [childId], references: [id], onDelete: Restrict)
  messages Message[]

  @@index([familyId])
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderType     MessageSenderType
  senderId       String?
  type           MessageType
  body           String?
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)

  @@index([conversationId])
}

model ConsentRecord {
  id        String      @id @default(cuid())
  familyId  String
  parentId  String?
  childId   String?
  type      ConsentType
  version   String
  grantedAt DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  family Family  @relation(fields: [familyId], references: [id], onDelete: Restrict)
  parent Parent? @relation(fields: [parentId], references: [id], onDelete: Restrict)
  child  Child?  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
}
