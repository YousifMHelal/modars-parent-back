datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum ParentRole {
  OWNER
  CO_PARENT
}

enum PrincipalType {
  PARENT
  CHILD
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

enum Gender {
  MALE
  FEMALE
}

enum ChildStatus {
  ACTIVE
  PAUSED
}

enum Curriculum {
  BRITISH
  AMERICAN
  IB
  SAUDI_NATIONAL
}

enum Trend {
  UP
  DOWN
  FLAT
}

enum HomeworkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  COMPLETED_LATE
}

enum PlanKey {
  STARTER
  FAMILY
  FAMILY_PRO
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  PAID
  OPEN
  VOID
}

enum ReminderType {
  DAILY_STUDY
  HOMEWORK_DUE
  STREAK_PROTECTION
  MISSED_SESSION
  WEEKLY_SUMMARY
  STRUGGLE_ALERT
  EXAM_COUNTDOWN
  ACHIEVEMENT
  REWARD_REDEEMED
}

enum ReminderRecipient {
  CHILD
  PARENT
  BOTH
}

enum NotificationRecipient {
  PARENT
  CHILD
}

enum RewardStatus {
  ACTIVE
  FULFILLED
  EXPIRED
}

enum RewardGoalMetric {
  XP
  SESSIONS
}

enum MessageType {
  TEXT
  VOICE
  IMAGE
}

enum MessageSenderType {
  PARENT
  TEACHER
  CHILD
}

enum ConsentType {
  TERMS
  PRIVACY
  COPPA
  MARKETING
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// ── Phase 5: Payment & subscription enums ─────────────────────────────────────

enum PaymentPurpose {
  ACTIVATION
  RENEWAL
  OVERFLOW
  UPGRADE
}

enum PaymentIntentStatus {
  CREATED
  SUCCEEDED
  FAILED
}

// ── Phase 6: Background jobs & notifications enums (data-model.md §G) ──────────

enum NotificationSource {
  REMINDER
  BILLING
  SYSTEM
}

enum NotificationChannel {
  PUSH
  EMAIL
  WHATSAPP
}

enum DispatchStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
  DEAD_LETTERED
}

enum PushPlatform {
  FCM
  APNS
}

// ── Phase 8: Compliance & hardening enums (data-model.md §B) ──────────────────

enum DataExportStatus {
  PENDING
  READY
  EXPIRED
  FAILED
}

// ── Models ────────────────────────────────────────────────────────────────────

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 8 (additive): account-deletion retain-then-purge. Mirrors the Child
  // soft-delete convention. Both null = active; both set = pending deletion.
  // The family-purge sweep selects deletedAt != null AND purgeAfter <= now
  // (data-model.md §A, FR-008/011).
  deletedAt  DateTime?
  purgeAfter DateTime?

  parents       Parent[]
  children      Child[]
  subscription  Subscription?
  sessions      Session[]
  subjectProgress SubjectProgress[]
  homework      Homework[]
  reminderConfigs ReminderConfig[]
  badges        Badge[]
  notifications Notification[]
  rewards       Reward[]
  conversations Conversation[]
  consentRecords ConsentRecord[]
  authSessions  AuthSession[]
  coParentInvitations CoParentInvitation[]
  paymentIntents PaymentIntent[]
  paymentMethods PaymentMethod[]
  pushTokens     PushToken[]
  dataExports    DataExport[]
}

model Parent {
  id            String     @id @default(cuid())
  familyId      String
  role          ParentRole
  fullName      String
  email         String     @unique
  phoneCountry  String?
  phoneNumber   String?
  country       String?
  dob           DateTime?
  passwordHash    String?
  emailVerifiedAt DateTime?
  notifyPush      Boolean    @default(true)
  notifyEmail     Boolean    @default(true)
  notifyWhatsapp  Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  family                   Family                   @relation(fields: [familyId], references: [id], onDelete: Restrict)
  consentRecords           ConsentRecord[]
  authSessions             AuthSession[]
  oauthAccounts            OAuthAccount[]
  emailVerificationTokens  EmailVerificationToken[]
  coParentInvitations      CoParentInvitation[]
  dataExports              DataExport[]

  @@index([familyId])
}

model Child {
  id                  String      @id @default(cuid())
  familyId            String
  displayName         String
  dob                 DateTime
  gender              Gender
  country             String
  grade               String
  curriculum          Curriculum
  subjects            String[]
  status              ChildStatus @default(ACTIVE)
  username            String
  usernameNormalized  String      @unique
  passwordHash        String?
  pinHash             String?

  // Snapshot stats (D6)
  minutesThisWeek     Int         @default(0)
  sessionsThisWeek    Int         @default(0)
  streak              Int         @default(0)
  totalXp             Int         @default(0)
  totalMinutes        Int         @default(0)
  badgesThisMonth     Int         @default(0)
  masteryPercentage   Int         @default(0)
  coveragePercentage  Int         @default(0)
  trendVsLastWeek     Int         @default(0)
  topSubject          String?

  // Gamification
  level               Int         @default(1)
  levelXp             Int         @default(0)
  levelMax            Int         @default(1000)
  nextLevel           Int         @default(2)
  streakTokens        Int         @default(0)

  // Parental controls
  bedtimeCutoff       String?
  allowedDays         String[]
  blockedSubjects     String[]

  // Login-card image (best-effort backfill after create, FR-011; null until generated)
  loginCardUrl        String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?
  // Phase 6 (additive): set to deletedAt + 7d on soft-delete, cleared on restore.
  // The purge worker selects purgeAfter <= now (data-model.md §E).
  purgeAfter          DateTime?

  family           Family            @relation(fields: [familyId], references: [id], onDelete: Restrict)
  sessions         Session[]
  subjectProgress  SubjectProgress[]
  homework         Homework[]
  badges           Badge[]
  reminderConfigs  ReminderConfig[]
  notifications    Notification[]
  rewards          Reward[]
  conversations    Conversation[]
  consentRecords   ConsentRecord[]
  authSessions     AuthSession[]
  pushTokens       PushToken[]
  struggleTrackers StruggleTracker[]

  @@index([familyId])
  @@index([purgeAfter])
}

model Plan {
  id                  String   @id @default(cuid())
  key                 PlanKey  @unique
  name                String
  subtitle            String
  childLimit          Int
  monthlyPriceMinor   Int
  yearlyPriceMinor    Int
  yearlyDiscountMinor Int
  currency            String
  features            String[]
  highlighted         Boolean  @default(false)
  hasFreeTrial        Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  familyId         String             @unique
  planId           String
  status           SubscriptionStatus
  billingCycle     BillingCycle
  childSlotsUsed   Int                @default(0)
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  // Phase 5 (additive): cancel-with-retain + provider linkage. A non-null future
  // canceledEffectiveAt with status CANCELED expresses "canceled but retained".
  canceledAt             DateTime?
  canceledEffectiveAt    DateTime?
  providerCustomerId     String?
  providerSubscriptionId String?

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Restrict)
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices Invoice[]
  paymentIntents PaymentIntent[]
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  issuedAt       DateTime
  amountMinor    Int
  currency       String
  status         InvoiceStatus
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
}

// ── Phase 5: Payment intents, webhook ledger, saved methods ───────────────────

model PaymentIntent {
  id                  String              @id @default(cuid())
  familyId            String
  subscriptionId      String
  purpose             PaymentPurpose
  expectedAmountMinor Int
  currency            String
  providerRef         String // provider charge/checkout id
  status              PaymentIntentStatus @default(CREATED)
  metadata            Json? // e.g. { childDraftId } for OVERFLOW
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  family       Family       @relation(fields: [familyId], references: [id], onDelete: Restrict)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([providerRef])
}

model WebhookEvent {
  id              String    @id @default(cuid())
  providerEventId String    @unique // the dedup key (research.md §3)
  type            String
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?

  @@index([providerEventId])
}

model PaymentMethod {
  id                String   @id @default(cuid())
  familyId          String
  providerMethodRef String // provider token; NEVER a raw card number
  brand             String // "visa" | "mada" | … (display only)
  last4             String // display only
  expMonth          Int
  expYear           Int
  isDefault         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)

  @@index([familyId])
}

model Session {
  id              String   @id @default(cuid())
  familyId        String
  childId         String
  subject         String
  startedAt       DateTime
  durationMinutes Int
  topics          String[]
  score           Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([childId])
}

model SubjectProgress {
  id            String    @id @default(cuid())
  familyId      String
  childId       String
  subject       String
  mastery       Int
  coverage      Int
  trend         Trend
  lastStudiedAt DateTime?
  masteryHistory Int[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  family Family         @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child          @relation(fields: [childId], references: [id], onDelete: Restrict)
  topics TopicProgress[]

  @@unique([childId, subject])
  @@index([familyId])
  @@index([childId])
}

model TopicProgress {
  id                String   @id @default(cuid())
  subjectProgressId String
  name              String
  mastery           Int
  struggling        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subjectProgress SubjectProgress @relation(fields: [subjectProgressId], references: [id], onDelete: Restrict)

  @@index([subjectProgressId])
}

model Homework {
  id       String         @id @default(cuid())
  familyId String
  childId  String
  subject  String
  topic    String
  deadline DateTime
  status   HomeworkStatus
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([childId])
}

model ReminderConfig {
  id        String            @id @default(cuid())
  familyId  String
  childId   String
  type      ReminderType
  enabled   Boolean
  recipient ReminderRecipient
  settings  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([childId, type])
  @@index([familyId])
  @@index([childId])
}

model Badge {
  id              String    @id @default(cuid())
  familyId        String
  childId         String
  key             String
  name            String
  emoji           String
  description     String
  criteria        String
  earned          Boolean   @default(false)
  earnedAt        DateTime?
  progressCurrent Int?
  progressTotal   Int?
  progressUnit    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([childId, key])
  @@index([familyId])
  @@index([childId])
}

model Notification {
  id        String                @id @default(cuid())
  familyId  String
  recipient NotificationRecipient
  childId   String?
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  // Phase 6 (additive) — central dispatch + daily cap (data-model.md §A).
  type             ReminderType?         // source reminder type (null for billing/system notices)
  source           NotificationSource    @default(SYSTEM)
  priorityRank     Int                   @default(0) // resolved per-type rank (1 = highest)
  channels         NotificationChannel[]             // delivery channels for this notification
  capDay           String?               // Asia/Riyadh civil date YYYY-MM-DD this counts against
  countsAgainstCap Boolean               @default(false)
  dispatchStatus   DispatchStatus        @default(PENDING)
  sentAt           DateTime?
  attemptCount     Int                   @default(0)

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child? @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([childId, capDay, type])
  @@index([familyId])
  @@index([childId, capDay])
}

// ── Phase 6: Push tokens, session-event ledger, struggle tracker ──────────────

model PushToken {
  id         String       @id @default(cuid())
  familyId   String
  parentId   String? // owning parent (parent-addressed push)
  childId    String? // owning child (child-addressed push)
  platform   PushPlatform
  token      String
  disabledAt DateTime? // set when the provider reports the token invalid
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child? @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([token])
  @@index([familyId])
  @@index([childId])
}

model ProcessedSessionEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique // dedup key from the AI-pipeline event (FR-019/022)
  childId     String
  familyId    String // resolved from the event payload (FR-003)
  outcome     String // started | completed | abandoned
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([eventId])
  @@index([childId])
}

model StruggleTracker {
  id                    String    @id @default(cuid())
  familyId              String
  childId               String
  topic                 String
  consecutiveLowMastery Int       @default(0)
  lastAlertedAt         DateTime?
  updatedAt             DateTime  @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@unique([childId, topic])
  @@index([familyId])
}

model Reward {
  id          String       @id @default(cuid())
  familyId    String
  childId     String?
  title       String
  description String?
  goalMetric  RewardGoalMetric?
  goalTarget  Int?
  goalCurrent Int?
  status      RewardStatus
  fulfilledAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child  Child? @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
}

model Conversation {
  id            String    @id @default(cuid())
  familyId      String
  childId       String?
  teacherId     String?
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Restrict)
  child    Child?    @relation(fields: [childId], references: [id], onDelete: Restrict)
  messages Message[]

  @@index([familyId])
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderType     MessageSenderType
  senderId       String?
  type           MessageType
  body           String?
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)

  @@index([conversationId])
}

model ConsentRecord {
  id        String      @id @default(cuid())
  familyId  String
  parentId  String?
  childId   String?
  type      ConsentType
  version   String
  grantedAt DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  family Family  @relation(fields: [familyId], references: [id], onDelete: Restrict)
  parent Parent? @relation(fields: [parentId], references: [id], onDelete: Restrict)
  child  Child?  @relation(fields: [childId], references: [id], onDelete: Restrict)

  @@index([familyId])
}

// ── Phase 8: Data export (data-model.md §B) ───────────────────────────────────

model DataExport {
  id                  String           @id @default(cuid())
  familyId            String
  requestedByParentId String
  status              DataExportStatus @default(PENDING)
  // Private object key `${familyId}/exports/${id}.json.gz`; null until READY.
  storageKey          String?
  requestedAt         DateTime         @default(now())
  readyAt             DateTime?
  expiresAt           DateTime?
  error               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  family            Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  requestedByParent Parent @relation(fields: [requestedByParentId], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([status, expiresAt])
}

// ── Phase 2: Auth models ──────────────────────────────────────────────────────

model AuthSession {
  id               String        @id @default(cuid())
  familyId         String
  principalType    PrincipalType
  parentId         String?
  childId          String?
  refreshTokenHash String
  expiresAt        DateTime
  rotatedAt        DateTime?
  replacedById     String?       @unique
  revokedAt        DateTime?
  deviceLabel      String?
  lastUsedAt       DateTime?
  createdAt        DateTime      @default(now())

  family     Family       @relation(fields: [familyId], references: [id], onDelete: Restrict)
  parent     Parent?      @relation(fields: [parentId], references: [id], onDelete: Restrict)
  child      Child?       @relation(fields: [childId], references: [id], onDelete: Restrict)
  replacedBy AuthSession? @relation("SessionLineage", fields: [replacedById], references: [id])
  replaces   AuthSession? @relation("SessionLineage")

  @@index([familyId])
  @@index([childId])
  @@index([parentId])
  @@index([expiresAt])
}

model OAuthAccount {
  id                String        @id @default(cuid())
  parentId          String
  provider          OAuthProvider
  providerAccountId String
  email             String?
  createdAt         DateTime      @default(now())

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([parentId])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  parentId   String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
}

// ── Phase 4: Co-parent invitations ────────────────────────────────────────────

model CoParentInvitation {
  id          String           @id @default(cuid())
  familyId    String
  invitedById String
  email       String
  tokenHash   String
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  family    Family @relation(fields: [familyId], references: [id], onDelete: Restrict)
  invitedBy Parent @relation(fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([familyId])
  @@index([tokenHash])
}
