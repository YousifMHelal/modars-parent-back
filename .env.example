# ─── Required ────────────────────────────────────────────────────────────────

# Application environment: development | test | production
NODE_ENV=development

# HTTP port to listen on
PORT=4000

# PostgreSQL connection string (required — never commit the real value)
# Phase 1: used by prisma migrate dev, prisma db seed, and the running server
DATABASE_URL=postgresql://user:password@localhost:5432/modars

# Redis connection string (provisioned for later phases; non-critical to /health)
REDIS_URL=redis://localhost:6379

# Comma-separated list of allowed CORS origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# Rate-limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per IP per window
RATE_LIMIT_MAX=100

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─── Auth — JWT ──────────────────────────────────────────────────────────────

# Secret used to sign access tokens (min 32 chars, keep secret)
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHAR_SECRET

# Secret used to sign refresh tokens (min 32 chars, keep secret)
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_CHAR_SECRET

# Access token TTL (e.g. 15m, 1h)
JWT_ACCESS_TTL=15m

# Refresh token TTL (e.g. 30d)
JWT_REFRESH_TTL=30d

# ─── Auth — Lockout ──────────────────────────────────────────────────────────

# Max consecutive failures before lockout
AUTH_LOCK_MAX_ATTEMPTS=5

# Lockout window (Redis TTL string, e.g. 15m)
AUTH_LOCK_WINDOW=15m

# ─── Auth — Shared device re-auth ────────────────────────────────────────────

# Sliding re-auth window (e.g. 15m)
REAUTH_WINDOW=15m

# When Redis is unavailable, whether the shared-device re-auth gate lets requests
# through (true) or rejects them with 503 (false). Defaults to fail-closed.
REAUTH_FAIL_OPEN=false

# ─── Mailer ──────────────────────────────────────────────────────────────────

# Transport: stub (logs link) | smtp
MAILER_TRANSPORT=stub

# From address for outgoing emails
MAILER_FROM=noreply@example.com

# SMTP settings (only needed when MAILER_TRANSPORT=smtp)
# MAILER_SMTP_HOST=smtp.example.com
# MAILER_SMTP_PORT=587
# MAILER_SMTP_USER=user
# MAILER_SMTP_PASS=password

# ─── OAuth — Google ──────────────────────────────────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/auth/oauth/google/callback

# ─── OAuth — Apple ───────────────────────────────────────────────────────────

# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=  # PEM key contents (newlines as \n)
# APPLE_CALLBACK_URL=http://localhost:4000/auth/oauth/apple/callback
